# ---------------------------------------------------------
# GlucoConnect Backend — Environment Variables Template
# ---------------------------------------------------------
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control!

# --- Server ---
PORT=3000
NODE_ENV=development

# --- MongoDB ---
# Local: mongodb://localhost:27017/glucoconnect
# Atlas: mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/glucoconnect
MONGO_URI=

# --- JWT Authentication ---
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# --- Fitbit OAuth 2.0 ---
# Register your app at: https://dev.fitbit.com/apps
# Set the OAuth 2.0 Application Type to "Personal"
# Set the Callback URL to match FITBIT_REDIRECT_URI below
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=http://localhost:3000/fitbit/callback

# --- Google Cloud Vision API ---
# Download a service account key from GCP Console:
#   IAM & Admin → Service Accounts → Create Key → JSON
# Set the path to the downloaded JSON file:
GOOGLE_APPLICATION_CREDENTIALS=
# Set to 'false' to bypass the Vision API entirely and conserve free quota
ENABLE_VISION_API=true
