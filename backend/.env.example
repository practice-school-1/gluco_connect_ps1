DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/glucoconnect_db"
JWT_SECRET="your-strong-secret-here"
PORT=3000

# Optional SMS delivery for OTPs. Checked in this order:
# 1. TWO_FACTOR_API_KEY (2Factor.in — works for Indian numbers)
# 2. TWILIO_ACCOUNT_SID/TWILIO_AUTH_TOKEN/TWILIO_PHONE_NUMBER
# If none are set, OTPs are printed to the console instead.
TWO_FACTOR_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Optional: rewrites rule-engine insight messages into more patient-friendly
# language via Groq (console.groq.com — free tier, no billing required).
# If unset, the raw rule-engine message is used as-is.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Fitbit OAuth (register an app at https://dev.fitbit.com/apps to get these).
# Must point at the frontend (not this backend) — Fitbit redirects the browser
# here with ?code=..., and the SPA exchanges it via an authenticated POST.
FITBIT_CLIENT_ID=""
FITBIT_CLIENT_SECRET=""
FITBIT_REDIRECT_URI="http://localhost:5173/patient/log-activity"
