DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/glucoconnect_db"
JWT_SECRET="your-strong-secret-here"
PORT=3000

# Optional SMS delivery for OTPs. Checked in this order:
# 1. TWO_FACTOR_API_KEY (2Factor.in — works for Indian numbers)
# 2. TWILIO_ACCOUNT_SID/TWILIO_AUTH_TOKEN/TWILIO_PHONE_NUMBER
# If none are set, OTPs are printed to the console instead.
TWO_FACTOR_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
